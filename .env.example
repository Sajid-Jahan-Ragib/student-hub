# Client
VITE_APP_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3001
VITE_WRITE_API_TOKEN=dev-admin-token
VITE_WRITE_SCOPE=student-hub-admin

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
MIRROR_DIST_WRITES=false
WRITE_API_TOKEN=dev-admin-token
WRITE_SCOPE=student-hub-admin
READ_SOURCE_MODE=auto
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_hub
STAGING_DATABASE_URL=postgresql://staging_user:staging_password@staging-host:5432/student_hub_staging
TUNNEL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:18789/student_hub
