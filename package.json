{
  "name": "student-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "start:server": "node server/index.js",
    "db:format": "prisma format --schema db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema db/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema db/prisma/schema.prisma",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs postgres --tail=100",
    "db:check:local": "node scripts/check-db-connection.mjs local",
    "db:check:staging": "node scripts/check-db-connection.mjs staging",
    "db:check:tunnel": "node scripts/check-db-connection.mjs tunnel",
    "db:import:dry": "node scripts/import-json-to-postgres.mjs --dry-run",
    "db:import": "node scripts/import-json-to-postgres.mjs",
    "db:verify:json": "node scripts/verify-json-vs-postgres.mjs --json-only",
    "db:verify": "node scripts/verify-json-vs-postgres.mjs",
    "db:verify:staging": "node scripts/verify-json-vs-postgres.mjs --env-key STAGING_DATABASE_URL",
    "db:verify:tunnel": "node scripts/verify-json-vs-postgres.mjs --env-key TUNNEL_DATABASE_URL",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{js,json,cjs,mjs,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{js,json,cjs,mjs,html,css}\"",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.31",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0",
    "vitest": "^0.34.6"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  }
}
